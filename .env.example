# ── Server ────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/quizgame
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────────
# REQUIRED in production — generate with: openssl rand -hex 64
JWT_SECRET=replace-me-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Refresh token secret — MUST differ from JWT_SECRET in production
JWT_REFRESH_SECRET=replace-me-with-a-different-long-random-secret
JWT_REFRESH_EXPIRES=30d

# ── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
FRONTEND_URL=http://localhost:3000

# ── Game settings ─────────────────────────────────────────────────────────
SNAPSHOT_INTERVAL=5
SOCKET_THROTTLE_MS=50
